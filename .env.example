# ============================================================
# PolyAgent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It contains your private key.
# ============================================================

# ── Trading Mode ─────────────────────────────────────────────
# "paper" = simulated fills (default, safe)
# "live"  = real orders on Polymarket via py-clob-client
POLYAGENT_MODE=paper

# ── Database ─────────────────────────────────────────────────
POLYAGENT_DB=./data/polyagent.db
POLYAGENT_DATA_DIR=./data

# ── Polymarket API (Required for LIVE mode) ──────────────────
#
# Your private key from Polymarket. To export it:
#   1. Go to polymarket.com/settings?tab=export-private-key
#      (or: Settings → Export Private Key)
#   2. If email login: you'll be redirected to reveal.magic.link/polymarket
#      Enter your email → click Magic Link in your inbox → Reveal Private Key
#   3. Copy the 64-character hex string (starts with 0x)
#   4. Remove the "0x" prefix — paste only the 64 hex characters below
#
# SECURITY: Never share this key. Never commit it to git.
POLYMARKET_PRIVATE_KEY=

# Your proxy wallet address (the "funder").
# This is the address shown on polymarket.com/settings
# It holds your USDC and outcome token positions.
# Example: 0x1234567890abcdef1234567890abcdef12345678
POLYMARKET_FUNDER_ADDRESS=

# Wallet signature type:
#   0 = EOA (MetaMask / hardware wallet)
#   1 = POLY_PROXY (Magic Link / email login — most common)
#   2 = GNOSIS_SAFE (multisig proxy)
#
# If you log in to Polymarket with EMAIL → use 1
# If you log in with MetaMask → use 0
POLYMARKET_SIGNATURE_TYPE=1

# CLOB API endpoint (Polygon mainnet — don't change)
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Polygon chain ID (137 = mainnet — don't change)
POLYMARKET_CHAIN_ID=137

# ── API Credentials (Auto-generated on first run) ───────────
# These are derived from your private key automatically.
# You can also set them manually if you already have them.
# If left empty, the bot will call create_or_derive_api_creds()
# on startup and populate these.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Capital Limits (Safety Rails) ────────────────────────────
# Maximum total capital the bot is allowed to deploy (USDC).
# The bot will NEVER exceed this, even if your wallet has more.
POLYAGENT_LIVE_CAPITAL=500.00

# Maximum single position size (USDC)
POLYAGENT_MAX_POSITION=100.00

# Maximum % of capital deployed at any time (0.0-1.0)
POLYAGENT_MAX_DEPLOYED_PCT=0.70

# Daily loss limit — bot stops trading if daily P&L drops below this
POLYAGENT_DAILY_LOSS_LIMIT=-50.00

# ── Frontend ─────────────────────────────────────────────────
API_URL=http://localhost:8765

# ── Polygon RPC (Required only for token allowances setup) ───
# Default public RPC works fine. Use a private one for reliability.
POLYGON_RPC_URL=https://polygon-rpc.com
